import jugador.*
import config.*


program galaga{
    game.title("Galaga")
    //Dimensiones del tablero
    game.height(15)
    game.width(15)
    game.cellSize(8)
    //Background 
    game.ground("background.png")
    //Controles 
    //Implementar
    //Visuals 
    game.addVisual(jugador)
    //keybinds 
    config.keybinds()
    game.start() 
}
